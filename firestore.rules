rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isCounselor() {
      return isSignedIn() && exists(/databases/$(database)/documents/counselors/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocAccessible(userId) {
       return isOwner(userId) || isCounselor();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      allow get: if isDocAccessible(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['category', 'domicile', 'savedColleges', 'displayName', 'notificationSettings']);
      
      // User documents
      match /documents/{docId} {
        allow read: if isDocAccessible(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isCounselor();
      }

      // Chat messages
      match /messages/{msgId} {
        allow read: if isDocAccessible(userId);
        allow create: if isDocAccessible(userId);
      }

      // User appointments
      match /appointments/{appointmentId} {
        allow list, get: if isDocAccessible(userId);
        allow create: if isOwner(userId) && isValidId(appointmentId);
        allow update: if isOwner(userId) || isCounselor();
      }
    }

    // Role-based access
    match /counselors/{counselorId} {
      allow read: if isSignedIn();
    }

    // Global notifications
    match /notifications/{notifId} {
      allow list, get: if isSignedIn();
      // Only admins (to be defined/manual) or system can write here
      allow write: if false; 
    }

    // Colleges listing
    match /colleges/{collegeId} {
      allow list, get: if true; // Publicly readable college data
      allow write: if false; // Only manageable via console or specialized scripts
    }
  }
}
